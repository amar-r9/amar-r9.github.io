<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Stagger reveals in grids
  document.querySelectorAll('.features-grid .feature-tile, .showcase-grid .showcase-card, .team-grid .team-card').forEach((el, i) => {
    el.style.transitionDelay = (i * 0.08) + 's';
  });

  // Contact form
  document.querySelector('.btn-submit').addEventListener('click', function() {
    const inputs = document.querySelectorAll('input, textarea');
    let filled = [...inputs].every(i => i.value.trim());
    if (filled) {
      this.textContent = '✓ Message Sent!';
      this.style.background = 'var(--teal)';
      inputs.forEach(i => i.value = '');
      setTimeout(() => { this.textContent = 'Send Message →'; this.style.background = 'var(--accent)'; }, 3000);
    } else {
      this.textContent = 'Please fill all fields';
      setTimeout(() => { this.textContent = 'Send Message →'; }, 2000);
    }
  });
</script>
</body>
</html>
