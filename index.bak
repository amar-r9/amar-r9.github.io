<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MySuperBrain — Where Young Talent Meets the World</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0a0a0f;
    --paper: #faf9f6;
    --accent: #ff4d2e;
    --accent2: #ffd23f;
    --teal: #00c9a7;
    --soft: #f0ede6;
    --muted: #888880;
    --card-bg: #ffffff;
    --nav-h: 72px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--paper);
    color: var(--ink);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--nav-h);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw;
    background: rgba(250,249,246,0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(10,10,15,.07);
    transition: background .3s;
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.35rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -.02em;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex; gap: 2rem; list-style: none;
  }
  .nav-links a {
    font-size: .88rem; font-weight: 500;
    color: var(--ink); text-decoration: none;
    letter-spacing: .02em;
    opacity: .65;
    transition: opacity .2s;
  }
  .nav-links a:hover { opacity: 1; }

  .nav-cta {
    background: var(--ink);
    color: var(--paper) !important;
    opacity: 1 !important;
    padding: .5rem 1.25rem;
    border-radius: 100px;
    font-size: .85rem !important;
    font-weight: 600 !important;
    transition: background .2s !important;
  }
  .nav-cta:hover { background: var(--accent) !important; }

  /* ── HERO ── */
  #home {
    min-height: 100vh;
    padding-top: var(--nav-h);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding-left: 8vw;
    padding-right: 5vw;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
  }
  .blob1 { width: 500px; height: 500px; background: rgba(255,77,46,.12); top: -80px; right: -120px; }
  .blob2 { width: 400px; height: 400px; background: rgba(0,201,167,.1); bottom: 0; left: 5%; }
  .blob3 { width: 300px; height: 300px; background: rgba(255,210,63,.12); top: 30%; right: 30%; }

  .hero-content { position: relative; z-index: 1; }

  .hero-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--soft); border: 1px solid rgba(10,10,15,.1);
    border-radius: 100px;
    padding: .35rem 1rem;
    font-size: .78rem; font-weight: 500;
    color: var(--muted);
    margin-bottom: 1.75rem;
    animation: fadeUp .6s ease both;
  }
  .hero-tag .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -.03em;
    animation: fadeUp .7s .1s ease both;
  }
  h1 .highlight {
    color: var(--accent);
    position: relative;
    display: inline-block;
  }
  h1 .highlight::after {
    content: '';
    position: absolute; left: 0; bottom: 4px;
    width: 100%; height: 6px;
    background: var(--accent2);
    border-radius: 3px;
    z-index: -1;
    transform: skewX(-4deg);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    color: #555;
    line-height: 1.7;
    max-width: 440px;
    font-weight: 300;
    animation: fadeUp .7s .2s ease both;
  }

  .hero-actions {
    margin-top: 2.5rem;
    display: flex; gap: 1rem; flex-wrap: wrap;
    animation: fadeUp .7s .3s ease both;
  }

  .btn-primary {
    background: var(--accent); color: #fff;
    padding: .85rem 2rem; border-radius: 100px;
    font-size: .95rem; font-weight: 600;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: .5rem;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(255,77,46,.3);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(255,77,46,.4); }

  .btn-ghost {
    background: transparent; color: var(--ink);
    padding: .85rem 2rem; border-radius: 100px;
    font-size: .95rem; font-weight: 500;
    text-decoration: none;
    border: 1.5px solid rgba(10,10,15,.2);
    transition: border-color .2s, background .2s;
  }
  .btn-ghost:hover { border-color: var(--ink); background: var(--soft); }

  .hero-stats {
    margin-top: 3rem;
    display: flex; gap: 2.5rem;
    animation: fadeUp .7s .4s ease both;
  }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 1.8rem; font-weight: 800;
    color: var(--ink);
  }
  .stat-label { font-size: .78rem; color: var(--muted); margin-top: .15rem; text-transform: uppercase; letter-spacing: .08em; }

  /* hero visual */
  .hero-visual {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 1rem;
    animation: fadeUp .8s .15s ease both;
  }

  .talent-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.25rem 1.5rem;
    display: flex; align-items: center; gap: 1rem;
    box-shadow: 0 4px 24px rgba(10,10,15,.06);
    border: 1px solid rgba(10,10,15,.05);
    transition: transform .3s;
  }
  .talent-card:hover { transform: translateX(6px); }

  .talent-emoji { font-size: 2rem; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; border-radius: 14px; flex-shrink: 0; }
  .tc1 .talent-emoji { background: #fff5f3; }
  .tc2 .talent-emoji { background: #f0fdf9; }
  .tc3 .talent-emoji { background: #fffbeb; }
  .tc4 .talent-emoji { background: #f5f0ff; }

  .talent-info strong { display: block; font-size: .9rem; font-weight: 600; color: var(--ink); }
  .talent-info span { font-size: .78rem; color: var(--muted); }

  .talent-badge {
    margin-left: auto;
    background: var(--teal);
    color: #fff;
    font-size: .7rem; font-weight: 600;
    padding: .25rem .7rem;
    border-radius: 100px;
    white-space: nowrap;
  }
  .badge-warm { background: var(--accent); }
  .badge-gold { background: var(--accent2); color: var(--ink); }

  /* ── SECTION SCAFFOLDING ── */
  section { padding: 7rem 8vw; }
  .section-eyebrow {
    font-size: .78rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .14em;
    color: var(--accent);
    margin-bottom: .75rem;
  }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -.025em;
    line-height: 1.1;
  }
  .section-sub {
    color: #666; font-size: 1rem; line-height: 1.7;
    font-weight: 300; max-width: 520px; margin-top: .75rem;
  }

  /* ── ABOUT ── */
  #about {
    background: var(--ink);
    color: var(--paper);
    border-radius: 32px;
    margin: 0 3vw;
    padding: 6rem 7vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  #about .section-eyebrow { color: var(--teal); }
  #about .section-title { color: var(--paper); }
  #about .section-sub { color: rgba(250,249,246,.6); }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .feature-tile {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 18px;
    padding: 1.5rem;
    transition: background .3s;
  }
  .feature-tile:hover { background: rgba(255,255,255,.09); }
  .feature-icon { font-size: 1.8rem; margin-bottom: .75rem; }
  .feature-tile h4 { font-family: 'Syne', sans-serif; font-size: .95rem; font-weight: 700; margin-bottom: .4rem; }
  .feature-tile p { font-size: .82rem; color: rgba(250,249,246,.55); line-height: 1.6; }

  /* ── COURSES STRIP ── */
  #courses {
    padding: 5rem 0;
    overflow: hidden;
  }
  .courses-header { padding: 0 8vw 2.5rem; }

  .courses-track {
    display: flex; gap: 1.25rem;
    animation: scroll-x 28s linear infinite;
    width: max-content;
  }
  @keyframes scroll-x {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .courses-track:hover { animation-play-state: paused; }

  .course-pill {
    background: var(--card-bg);
    border: 1px solid rgba(10,10,15,.08);
    border-radius: 100px;
    padding: .9rem 1.6rem;
    display: flex; align-items: center; gap: .7rem;
    font-size: .9rem; font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(10,10,15,.04);
    cursor: default;
    transition: box-shadow .2s;
  }
  .course-pill:hover { box-shadow: 0 4px 20px rgba(10,10,15,.1); }
  .course-pill .ce { font-size: 1.2rem; }

  /* ── SHOWCASE ── */
  #showcase { background: var(--soft); }
  .showcase-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .showcase-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(10,10,15,.06);
    transition: transform .3s, box-shadow .3s;
  }
  .showcase-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(10,10,15,.1); }

  .sc-img {
    width: 100%; aspect-ratio: 1;
    background: linear-gradient(135deg, #f5e6e6, #e6f5f0);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    position: relative;
    overflow: hidden;
  }
  .sc-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .sc-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,15,.5), transparent);
    opacity: 0;
    transition: opacity .3s;
  }
  .showcase-card:hover .sc-overlay { opacity: 1; }

  .sc-label {
    padding: 1rem 1.1rem;
    font-size: .82rem;
    font-weight: 500;
    color: var(--muted);
  }
  .sc-label strong { display: block; font-size: .92rem; color: var(--ink); margin-bottom: .1rem; }

  /* ── TESTIMONIALS ── */
  #testimonials {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    padding: 7rem 8vw;
    align-items: start;
  }
  .testi-header { grid-column: 1 / -1; margin-bottom: .5rem; }

  .testi-card {
    background: var(--card-bg);
    border: 1px solid rgba(10,10,15,.07);
    border-radius: 24px;
    padding: 2rem;
    position: relative;
    transition: transform .3s, box-shadow .3s;
  }
  .testi-card:hover { transform: translateY(-4px); box-shadow: 0 10px 40px rgba(10,10,15,.08); }
  .testi-card.featured {
    background: var(--ink);
    color: var(--paper);
  }
  .testi-card.featured .testi-name { color: var(--paper); }
  .testi-card.featured .testi-role { color: rgba(250,249,246,.5); }

  .quote-mark {
    font-family: 'Syne', sans-serif;
    font-size: 4rem; line-height: .8;
    color: var(--accent);
    margin-bottom: .5rem;
    font-weight: 800;
  }
  .testi-text { font-size: .9rem; line-height: 1.75; color: #555; font-weight: 300; }
  .featured .testi-text { color: rgba(250,249,246,.7); }

  .testi-author {
    display: flex; align-items: center; gap: .85rem;
    margin-top: 1.5rem;
  }
  .testi-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover;
    background: var(--soft);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .testi-name { font-size: .9rem; font-weight: 600; color: var(--ink); }
  .testi-role { font-size: .75rem; color: var(--muted); }

  /* ── TEAM ── */
  #team { padding: 7rem 8vw; }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .team-card {
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    aspect-ratio: .8;
    cursor: pointer;
  }
  .team-card img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .5s;
    filter: grayscale(20%);
  }
  .team-card:hover img { transform: scale(1.05); filter: grayscale(0%); }
  .team-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,15,.85) 0%, transparent 55%);
  }
  .team-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 2rem;
    color: var(--paper);
  }
  .team-info h3 { font-family: 'Syne', sans-serif; font-size: 1.35rem; font-weight: 800; }
  .team-role { font-size: .8rem; color: var(--teal); font-weight: 600; text-transform: uppercase; letter-spacing: .1em; margin-bottom: .5rem; }
  .team-bio { font-size: .82rem; color: rgba(250,249,246,.7); line-height: 1.6; margin-top: .5rem; max-height: 0; overflow: hidden; transition: max-height .4s; }
  .team-card:hover .team-bio { max-height: 120px; }
  /* placeholder team bg */
  .team-placeholder { width: 100%; height: 100%; object-fit: cover; }
  .tph1 { background: linear-gradient(135deg, #1a1a2e, #16213e); }
  .tph2 { background: linear-gradient(135deg, #0f3460, #533483); }
  .tph3 { background: linear-gradient(135deg, #2d1b69, #11998e); }

  /* ── CONTACT ── */
  #contact {
    background: var(--ink);
    border-radius: 32px;
    margin: 0 3vw 4rem;
    padding: 6rem 7vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    color: var(--paper);
  }
  #contact .section-eyebrow { color: var(--teal); }
  #contact .section-title { color: var(--paper); }
  #contact .section-sub { color: rgba(250,249,246,.55); }

  .contact-info { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex; align-items: center; gap: 1rem;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    padding: 1rem 1.25rem;
    font-size: .9rem;
    color: rgba(250,249,246,.8);
  }
  .contact-item .ci { font-size: 1.25rem; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  input, textarea {
    width: 100%;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 14px;
    padding: .95rem 1.25rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .9rem;
    color: var(--paper);
    outline: none;
    transition: border-color .2s;
    resize: none;
  }
  input::placeholder, textarea::placeholder { color: rgba(250,249,246,.35); }
  input:focus, textarea:focus { border-color: var(--teal); }

  .btn-submit {
    background: var(--accent); color: #fff;
    padding: 1rem 2rem; border-radius: 100px;
    font-size: .95rem; font-weight: 600;
    border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: transform .2s, box-shadow .2s;
    align-self: flex-start;
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,77,46,.4); }

  /* ── DOWNLOAD ── */
  #download {
    padding: 6rem 8vw;
    display: flex; align-items: center; justify-content: space-between; gap: 3rem;
    flex-wrap: wrap;
  }
  .download-text .section-title { max-width: 500px; }
  .download-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .app-btn {
    background: var(--ink); color: var(--paper);
    border-radius: 16px;
    padding: .85rem 1.75rem;
    text-decoration: none;
    display: flex; align-items: center; gap: .85rem;
    transition: background .2s, transform .2s;
    border: 1.5px solid transparent;
  }
  .app-btn:hover { background: #1e1e2a; transform: translateY(-2px); }
  .app-btn .ab-icon { font-size: 1.8rem; }
  .ab-text small { display: block; font-size: .7rem; color: rgba(250,249,246,.5); text-transform: uppercase; letter-spacing: .08em; }
  .ab-text strong { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    color: rgba(250,249,246,.55);
    padding: 4rem 8vw 2rem;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .footer-brand .nav-logo { color: var(--paper); }
  .footer-brand p { margin-top: .75rem; font-size: .85rem; line-height: 1.7; max-width: 280px; }
  .footer-col h5 {
    font-family: 'Syne', sans-serif;
    font-size: .85rem; font-weight: 700;
    color: var(--paper);
    margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: .1em;
  }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
  .footer-col a { color: rgba(250,249,246,.5); text-decoration: none; font-size: .85rem; transition: color .2s; }
  .footer-col a:hover { color: var(--paper); }

  .footer-bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1.5rem;
    font-size: .8rem;
  }
  .social-links { display: flex; gap: 1rem; }
  .social-links a {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,.07);
    display: flex; align-items: center; justify-content: center;
    font-size: .95rem; text-decoration: none;
    transition: background .2s;
  }
  .social-links a:hover { background: rgba(255,255,255,.15); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0; transform: translateY(28px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    #home { grid-template-columns: 1fr; padding-top: calc(var(--nav-h) + 2rem); }
    .hero-visual { display: none; }
    #about, #contact { grid-template-columns: 1fr; margin: 0; border-radius: 0; gap: 3rem; }
    #testimonials { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr 1fr; }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .nav-links { display: none; }
  }
  @media (max-width: 600px) {
    section, #download { padding: 4rem 6vw; }
    .team-grid { grid-template-columns: 1fr; }
    .footer-top { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#home" class="nav-logo">My<span>Super</span>Brain</a>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#showcase">Showcase</a></li>
    <li><a href="#team">Team</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="#download" class="nav-cta">Download App</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="home">
  <div class="hero-bg-blob blob1"></div>
  <div class="hero-bg-blob blob2"></div>
  <div class="hero-bg-blob blob3"></div>

  <div class="hero-content">
    <div class="hero-tag">
      <span class="dot"></span>
      India's Leading Student Talent Platform
    </div>
    <h1>Where Young <span class="highlight">Talent</span><br>Meets the World</h1>
    <p class="hero-sub">MySuperBrain is a purpose-built platform that empowers students to discover their strengths, develop real-world skills, and share their talents with a global audience — far beyond marks and report cards.</p>
    <div class="hero-actions">
      <a href="#download" class="btn-primary">Get Started →</a>
      <a href="#about" class="btn-ghost">Learn More</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">10K+</div>
        <div class="stat-label">Active Students</div>
      </div>
      <div>
        <div class="stat-num">15+</div>
